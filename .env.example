# ── ProductHunt API Token ──────────────────────────────────────
# 免费申请地址：https://www.producthunt.com/v2/oauth/applications
# 选择 "Developer Token"（无需用户登录授权，直接使用）
# 免费额度：200 次/天
PRODUCT_HUNT_TOKEN=your_token_here

# ── 预留：其他工具 API（暂未接入）──────────────────────────────
# 搜索趋势数据源：hybrid | google_trends | serpapi | mock
SERPAPI_KEY=your_serpapi_key_here
SEARCH_TRENDS_PROVIDER=hybrid

# 内容热度数据源：hybrid | youtube | reddit | mock
CONTENT_HEAT_PROVIDER=hybrid
YOUTUBE_API_KEY=your_youtube_api_key_here

# YouTube Data API v3 key（可选，content_heat 在 hybrid/youtube 模式会使用）
# YOUTUBE_API_KEY=your_youtube_api_key_here

# 未能成功注册dataforseo，暂时无法提供流量数据相关功能，使用mock代替
TRAFFIC_PROVIDER=hybrid
DATAFORSEO_LOGIN=your_email@example.com
DATAFORSEO_PASSWORD=your_dataforseo_password

REVIEW_SENTIMENT_PROVIDER=hybrid
APPLE_REVIEW_REGION=cn
